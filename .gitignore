# Yui-Drop .gitignore

# Secrets
.env
.env.local
.env.*.local
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Node
node_modules/
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
.vite/
*.tsbuildinfo
.pnpm-store/
pnpm-lock.yaml.bak

# Data
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo
.history/

# Docker
.docker/
docker-compose.override.yml

# Build artifacts
backend/dist/
frontend/dist/
# Frontend dist copied for backend SPA fallback (regenerated by docker build)
frontend-dist/
# Subagent implementation reports (working notes, not source)
IMPLEMENTATION_REPORT.md
**/IMPLEMENTATION_REPORT.md

# Temp
tmp/
*.tmp
