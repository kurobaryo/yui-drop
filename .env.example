# ===========================================================================
# Yui-Drop — environment variables
#
# Copy this file to `.env` and edit the values you care about.
# Never commit the real .env to git — it contains secrets.
# ===========================================================================

# ─── Core ────────────────────────────────────────────────────────────────────
# Public URL the app is served on (used for share links, CORS, etc.)
APP_URL=http://localhost:8000

# Display name shown in the UI and emails
APP_NAME=Yui-Drop

# Comma-separated CORS whitelist. NEVER set to "*" in production.
# Default is APP_URL only.
ALLOWED_ORIGINS=http://localhost:8000

# ─── Secrets ─────────────────────────────────────────────────────────────────
# Initial admin token. Generated automatically by scripts/install.sh.
# After first start, change via /admin/settings; the value here is only used
# until the first login.
ADMIN_TOKEN=

# JWT signing secret. MUST be a strong random string (≥ 32 chars).
# Generated automatically by scripts/install.sh.
JWT_SECRET=

# JWT algorithm. HS256 is the default; for RS256 also set JWT_PRIVATE_KEY.
JWT_ALGORITHM=HS256

# Token lifetime (admin sessions). Default 30 days.
JWT_TTL_DAYS=30

# AES-256-GCM key used to encrypt at-rest secrets stored in settings_kv
# (e.g. S3 secret_access_key configured via the admin UI). MUST be a
# base64url-encoded 32-byte value. Generate with:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# The app refuses to start if this is empty.
SECRETS_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# Default: SQLite in a Docker volume. For Postgres, set e.g.
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/yui-drop.db

# ─── Storage backend ─────────────────────────────────────────────────────────
# One of: local | s3 | onedrive | webdav
STORAGE_BACKEND=local

# Local backend (relative to backend container)
LOCAL_STORAGE_DIR=./data/uploads

# S3 / Cloudflare R2 (also used by any S3-compatible service)
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION_NAME=auto
# Public hostname for downloads if your bucket has a custom domain (optional).
# Leave empty to use S3_ENDPOINT_URL.
S3_PUBLIC_HOSTNAME=

# OneDrive (optional; configure via admin UI is also fine)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REFRESH_TOKEN=

# WebDAV (optional)
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=

# ─── Limits & rate limiting ──────────────────────────────────────────────────
# Pickup code length (5–8 supported). Default 6.
PICKUP_CODE_LENGTH=6

# Per-IP upload caps
RATE_LIMIT_UPLOAD_PER_MIN=5
RATE_LIMIT_UPLOAD_PER_HOUR=30
RATE_LIMIT_UPLOAD_PER_DAY=200

# Per-IP retrieval brute-force protection
RATE_LIMIT_RETRIEVE_FAILS_PER_HOUR=20
RETRIEVE_BAN_DURATION_MIN=60

# Per-IP admin login attempts
RATE_LIMIT_LOGIN_PER_5MIN=10

# Single file size cap (bytes). Default 10 GiB.
MAX_UPLOAD_BYTES=10737418240

# Text-share size cap (bytes). Default 256 KiB.
MAX_TEXT_BYTES=262144

# Total storage cap across all shares (bytes). Empty = unlimited.
STORAGE_QUOTA_BYTES=

# How often the expire/orphan sweeper runs (minutes)
EXPIRE_SWEEPER_INTERVAL_MIN=10

# Orphan multipart session TTL (minutes); after this the session is aborted
# and any partially-uploaded parts in the bucket are deleted.
MULTIPART_SESSION_TTL_MIN=60

# ─── Bot protection (optional) ──────────────────────────────────────────────
# Cloudflare Turnstile keys. If both are set, the admin can toggle the
# challenge on from the settings UI; otherwise it stays hidden.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Logging ────────────────────────────────────────────────────────────────
# json | pretty
LOG_FORMAT=json
LOG_LEVEL=INFO

# Record client IP and User-Agent on every share create/retrieve.
# Required for abuse triage; disabling this is NOT recommended.
LOG_ACCESS_REQUESTS=true

# ─── Frontend build (used at docker build time only) ────────────────────────
# Public site name (overrides APP_NAME in the UI if set).
VITE_PUBLIC_NAME=
# Optional override for the API base; default = same origin.
VITE_API_BASE=
